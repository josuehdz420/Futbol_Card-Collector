{
  "name": "worldcup-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n ASTRO,API -c blue,green \"npm:dev:astro\" \"npm:dev:server\"",
    "dev:astro": "astro dev",
    "dev:server": "npm --prefix server run dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "postinstall": "npm install --prefix server"
  },
  "dependencies": {
    "astro": "^6.4.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
