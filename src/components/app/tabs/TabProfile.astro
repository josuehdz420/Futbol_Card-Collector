---

// Responsabilidad: pestaña "Perfil" — tarjeta de usuario (avatar, nombre,
// correo editable), estadísticas de juego, listas de favoritos, historial
// de predicciones, acciones sobre datos (export/import/convertir duplicados),
// tarjeta de Discord y sección de instalación de la PWA.

---
<section id="tab-profile" class="tab-section">
  <div class="section-header"><h2><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Mi Perfil</h2></div>
  <div class="profile-card" id="profile-card">
    <div class="profile-avatar-wrap">
      <div class="profile-avatar" id="profile-avatar"></div>
      <button class="btn-avatar-edit" id="btn-edit-avatar" title="Cambiar foto">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </button>
      <input type="file" id="input-avatar-file" accept="image/*" style="display:none">
    </div>
    <div class="profile-info">
      <div class="profile-field-row">
        <h3 id="profile-name">Jugador</h3>
        <button class="btn-field-edit" id="btn-edit-name" title="Editar nombre">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
      </div>
      <div class="profile-field-row">
        <p id="profile-email">-</p>
        <button class="btn-field-edit" id="btn-edit-email" title="Editar correo">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
      </div>
      <p id="profile-date">Registrado: -</p>
    </div>
    <div class="profile-stats">
      <div class="pstat"><span id="ps-figuritas">0</span><label>Figuritas</label></div>
      <div class="pstat"><span id="ps-tiradas">0</span><label>Tiradas</label></div>
      <div class="pstat"><span id="ps-aciertos">0</span><label>Aciertos</label></div>
      <div class="pstat"><span id="ps-monedas">0</span><label>Monedas</label></div>
    </div>
    <div class="profile-battle-stats">
      <div class="pstat"><span id="ps-wins">0</span><label>Victorias</label></div>
      <div class="pstat"><span id="ps-losses">0</span><label>Derrotas</label></div>
    </div>
  </div>
  <div class="profile-section">
    <h3>Equipos Favoritos</h3>
    <div id="fav-teams-list" class="fav-list"></div>
  </div>
  <div class="profile-section">
    <h3>Jugadores Favoritos</h3>
    <div id="fav-players-list" class="fav-list"></div>
  </div>
  <div class="profile-section">
    <h3>Historial de Predicciones</h3>
    <div id="bet-history" class="bet-history"></div>
  </div>
  <div class="profile-section">
    <h3>Datos</h3>
    <div class="data-actions" style="flex-direction:column">
      <button class="btn btn-sm" id="btn-convert-dupes">🔄 Convertir duplicados → monedas</button>
      <button class="btn btn-secondary" id="btn-export">📥 Exportar JSON</button>
      <label class="btn btn-secondary" id="label-import">
        📤 Importar JSON
        <input type="file" id="btn-import" accept=".json" style="display:none"/>
      </label>
    </div>
  </div>
  <div class="profile-section profile-discord-section">
    <h3>
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="vertical-align:-3px;margin-right:6px;color:#5865F2" aria-hidden="true">
        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
      </svg>Servidor de Discord
    </h3>
    <div class="discord-profile-card">
      <div class="discord-profile-top">
        <div class="discord-profile-avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="white">
            <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
          </svg>
        </div>
        <div class="discord-profile-info">
          <p class="discord-profile-name">WCC UES · Copa del Mundo 2026</p>
          <p class="discord-profile-desc">Sigue los partidos en vivo a través de nuestro servidor de discord 🏆</p>
        </div>
      </div>
      <a class="btn-discord-join" href="https://discord.gg/qGh7hYqshf" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
        </svg>
        Unirse al servidor
      </a>
    </div>
  </div>

  <div class="profile-section" id="profile-pwa-section" style="display:none">
    <h3>Aplicación</h3>
    <button id="btn-install-pwa-profile" class="btn-install-pwa-profile">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Instalar aplicación (PWA)
    </button>
    <p style="font-size:0.72rem;color:var(--text-muted);margin-top:0.4rem;text-align:center">Instala la app en tu dispositivo para acceder sin navegador</p>
  </div>
</section>
