---

// Responsabilidad: pestaña "Álbum" — filtros de rareza, grid de figuritas

---
<section id="tab-album" class="tab-section">
  <div class="section-header">
    <h2><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:6px"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>Mi Álbum</h2>
    <span class="album-progress-label" id="album-pct">0% completado</span>
  </div>
  <div class="album-filters">
    <button class="filt active" data-filt="all">Todas</button>
    <button class="filt" data-filt="common">Común</button>
    <button class="filt" data-filt="rare">Rara</button>
    <button class="filt" data-filt="epic">Épica</button>
    <button class="filt" data-filt="legendary">Legendaria</button>
    <button class="filt" data-filt="goat" style="background:linear-gradient(135deg,#ff2244,#ff6622);color:white;border-color:#ff2244">🐐 GOAT</button>
  </div>
  <div class="album-progress-bar">
    <div class="progress-fill" id="album-bar" style="width:0%"></div>
  </div>
  <div id="album-grid" class="album-grid"></div>
  <div class="section-header" style="margin-top:2rem;">
    <h2><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:6px"><circle cx="12" cy="12" r="10"/><path d="M12 8l1.5 3h3l-2.5 1.8.9 3-2.9-2.1L9.1 16l.9-3L7.5 11h3z"/></svg>Equipo Ideal</h2>
    <button class="btn btn-sm" id="btn-save-team">💾 Guardar</button>
  </div>
  <div id="ideal-team" class="ideal-team">
    <div class="formation-selector-wrap">
      <span class="formation-label">Formación:</span>
      <div id="formation-selector" class="formation-selector"></div>
    </div>
    <div class="formation" id="formation-field"></div>
  </div>
</section>
