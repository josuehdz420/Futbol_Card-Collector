---

// Responsabilidad: cabecera superior fija de la app (saludo al usuario,
// contadores de tiradas/monedas y botón de logout). Contenido estático;
// los valores se rellenan en runtime vía JS existente (#hdr-tiradas, etc.).
---
<header class="app-header">
  <div class="header-left"></div>
  <div class="header-center">
    <span id="header-greeting">Hola, Jugador</span>
  </div>
  <div class="header-right">
    <span class="header-stat" id="hdr-tiradas"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg> <strong>0</strong></span>
    <span class="header-stat" id="hdr-monedas">🪙 <strong>0</strong></span>
    <button class="btn-icon" id="btn-logout" title="Cerrar sesión"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></button>
  </div>
</header>
