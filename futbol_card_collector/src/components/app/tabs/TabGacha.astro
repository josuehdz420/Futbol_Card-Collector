---

// Responsabilidad: pestaña "Sobres" (gacha) — animación del sobre,

---
<section id="tab-gacha" class="tab-section">
  <div class="section-header"><h2><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:6px"><rect x="2" y="4" width="14" height="18" rx="2"/><path d="M8 22h12a2 2 0 002-2V8a2 2 0 00-2-2h-2"/></svg>Sobres</h2></div>
  <div class="gacha-center">
    <div class="sobre-stage">
      <div class="sobre-wrapper" id="sobre-wrapper">
        <div class="sobre sobre-closed" id="sobre-closed">
          <div class="sobre-top-flap"></div>
          <div class="sobre-body">
            <div class="sobre-logo">
              <div class="sobre-trophy">🏆</div>
              <div class="sobre-wc-text">FIFA</div>
              <div class="sobre-wc-year">WORLD CUP 2026™</div>
              <div class="sobre-panini">OFFICIAL STICKER COLLECTION</div>
              <div class="sobre-stars">★ ★ ★ ★ ★</div>
              <div class="sobre-countries">🇺🇸 🇨🇦 🇲🇽</div>
            </div>
            <div class="sobre-bottom-strip"></div>
          </div>
          <div class="sobre-shine"></div>
        </div>
        <div class="sobre-open" id="sobre-open" style="display:none;"></div>
      </div>

      <div class="sobre-info">
        <div class="sobre-tiradas-badge">
          <span class="sobre-tiradas-num" id="gacha-count">0</span>
          <span class="sobre-tiradas-lbl">sobres disponibles</span>
        </div>
        <div class="pity-section">
          <div class="pity-label">Garantía legendaria <span id="pity-display">0/50</span></div>
          <div class="pity-bar-track"><div class="pity-bar-fill" id="pity-bar" style="width:0%"></div></div>
        </div>
      </div>

      <div class="gacha-btns">
        <button class="btn btn-sobre-1" id="btn-gacha-1">
          <span class="sobre-btn-icon">📦</span>
          <span class="sobre-btn-text">Abrir 1 sobre</span>
          <span class="sobre-btn-sub">1 figurita</span>
        </button>
        <button class="btn btn-sobre-10" id="btn-gacha-10">
          <span class="sobre-btn-icon">🗃️</span>
          <span class="sobre-btn-text">Abrir 10 sobres</span>
          <span class="sobre-btn-sub">10 figuritas · más probabilidad ★</span>
        </button>
      </div>
    </div>

    <div class="gacha-result" id="gacha-result" style="display:none;"></div>

    <div class="rarity-legend">
      <span class="rarity common">Común 70%</span>
      <span class="rarity rare">Rara 20%</span>
      <span class="rarity epic">Épica 9%</span>
      <span class="rarity legendary">Legendaria 0.7%</span>
      <span class="rarity legendary" style="background:linear-gradient(135deg,#ff2244,#ff6622);color:white">🐐 GOAT 0.3%</span>
    </div>
  </div>
</section>
